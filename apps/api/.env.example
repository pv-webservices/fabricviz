# Server Configuration
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fabricviz

# Redis (For BullMQ & Rate Limiting)
REDIS_URL=redis://localhost:6379

# Authentication
# Must be at least 32 characters for HS256
JWT_SECRET=super_secret_key_change_in_production
JWT_EXPIRY=7d

# File Uploads (Optional: Cloud Storage Configs for v2)
STORAGE_MODE=local
UPLOAD_DIR=./uploads

# Nano Banana AI — REQUIRED for live rendering (set NANO_BANANA_API_KEY, leave empty for mock mode)
NANO_BANANA_API_URL=https://api.nanobanana.ai/v1/render
NANO_BANANA_API_KEY=your_api_key_here
NANO_BANANA_FAST_MODEL_ID=nano-banana-2.0
NANO_BANANA_PRO_MODEL_ID=nano-banana-pro
