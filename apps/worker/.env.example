# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fabricviz

# Redis (For BullMQ)
REDIS_URL=redis://localhost:6379

# Nano Banana / Gemini API
# Set to a real Gemini key (starts with AIza or AQ.) for LIVE rendering
# Set to "mock" or leave empty for MOCK mode (returns placeholder image)
NANO_BANANA_API_KEY=your_nano_banana_key_here
NANO_BANANA_API_URL=https://api.nanobanana.com/v2/generate

# MinIO URL rewriting — required for Gemini API to fetch room/fabric images
# MINIO_INTERNAL_HOST is the Docker-internal hostname (unreachable outside containers)
# MINIO_PUBLIC_URL is the publicly accessible URL (ngrok/CDN in dev, production domain in prod)
MINIO_INTERNAL_HOST=minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
