{
  "name": "fabricviz",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "seed": "npx tsx scripts/seed-dev.ts"
  },
  "devDependencies": {
