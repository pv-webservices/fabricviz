# Database
DATABASE_URL=postgresql://fabricviz:password@localhost:5432/fabricviz
POSTGRES_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=supersecretjwtkey_change_me_in_prod
JWT_EXPIRY=7d
ADMIN_JWT_SECRET=supersecretadminjwtkey_change_me_in_prod

# Nano Banana 2.0 (NEVER expose to frontend)
NANO_BANANA_API_KEY=your_nano_banana_api_key
NANO_BANANA_API_URL=https://api.nanobanana.ai/v2

# Storage (Cloudflare R2 or MinIO)
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=fabricviz

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# App
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# Storage Mode (local | r2 | s3)
STORAGE_MODE=local
LOCAL_UPLOAD_DIR=./uploads

# Logging
LOG_FILE_PATH=./logs/fabricviz-api.log
